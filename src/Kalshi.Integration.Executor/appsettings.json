{
  "ConnectionStrings": {
    "Executor": "Data Source=kalshi-integration-executor.db"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "guest",
    "Password": "guest",
    "Exchange": "kalshi.integration.events",
    "ExchangeType": "topic",
    "RoutingKeyPrefix": "kalshi.integration",
    "Mandatory": true,
    "PublisherResultsQueue": "kalshi.integration.event-publisher.results",
    "PublisherResultsDeadLetterQueue": "kalshi.integration.event-publisher.results.dlq",
    "ExecutorQueue": "kalshi.integration.executor",
    "ExecutorDeadLetterQueue": "kalshi.integration.executor.dlq",
    "ExecutorRoutingKeyBinding": "kalshi.integration.trading.#",
    "ResultsRoutingKeyBinding": "kalshi.integration.results.#",
    "PublishRetryAttempts": 2,
    "PublishRetryDelayMilliseconds": 250,
    "PublishConfirmTimeoutMilliseconds": 5000,
    "OutboxBatchSize": 25,
    "OutboxPollingIntervalMilliseconds": 1000,
    "QueueMonitoringIntervalMilliseconds": 5000,
    "OutboxLeaseDurationSeconds": 30,
    "OutboxMaxAttempts": 10,
    "OutboxInitialRetryDelayMilliseconds": 500,
    "OutboxMaxRetryDelayMilliseconds": 30000,
    "OutboxJitterMaxMilliseconds": 250,
    "RepairBatchSize": 25,
    "RepairGraceSeconds": 30,
    "OutboxDegradedAgeSeconds": 30,
    "OutboxUnhealthyAgeSeconds": 300,
    "CriticalQueueBacklogDegradedAgeSeconds": 30,
    "CriticalQueueBacklogUnhealthyAgeSeconds": 300,
    "EnableResultConsumer": true,
    "ConsumerRecoveryDelaySeconds": 5,
    "ClientProvidedName": "kalshi-integration-executor"
  },
  "Integrations": {
    "KalshiApi": {
      "BaseUrl": "https://api.elections.kalshi.com/trade-api/v2",
      "Subaccount": 0,
      "TimeoutSeconds": 20,
      "UserAgent": "kalshi-integration-executor/1.0"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "Kalshi.Integration.Executor",
    "ServiceVersion": "v1",
    "OtlpEndpoint": null
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
