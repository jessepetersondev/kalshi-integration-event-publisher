{
  "ConnectionStrings": {
    "KalshiIntegration": "Data Source=kalshi-integration-sandbox.db"
  },
  "Risk": {
    "MaxOrderSize": 10,
    "RejectDuplicateCorrelationIds": true
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "EventPublishing": {
    "Provider": "InMemory"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "guest",
    "Password": "guest",
    "Exchange": "kalshi.integration.events",
    "ExchangeType": "topic",
    "RoutingKeyPrefix": "kalshi.integration",
    "Mandatory": false,
    "ClientProvidedName": "kalshi-integration-sandbox"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
