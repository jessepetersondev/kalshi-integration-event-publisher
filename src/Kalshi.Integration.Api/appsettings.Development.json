{
  "ConnectionStrings": {
    "KalshiIntegration": "Data Source=kalshi-integration-sandbox.dev.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "Risk": {
    "MaxOrderSize": 10,
    "RejectDuplicateCorrelationIds": true
  },
  "Authentication": {
    "Jwt": {
      "SigningKey": "kalshi-integration-sandbox-local-dev-signing-key-please-change",
      "EnableDevelopmentTokenIssuance": true
    }
  },
  "OpenApi": {
    "EnableSwaggerInNonDevelopment": false
  },
  "Integrations": {
    "NodeGateway": {
      "Enabled": true,
      "BaseUrl": "http://localhost:3001",
      "HealthPath": "/health",
      "TimeoutSeconds": 5,
      "RetryAttempts": 2,
      "IncludeInReadiness": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
